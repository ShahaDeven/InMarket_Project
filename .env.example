# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# FRED API key — free, from https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Anthropic API key — from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model the agent uses (optional; default shown)
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- MCP server bind (optional; these are the defaults) ---
MCP_HOST=0.0.0.0
MCP_PORT=8000

# Where the agent finds the MCP server (optional).
#   - Local (both run on the host):   http://127.0.0.1:8000/mcp/   (default)
#   - Docker Compose sets this automatically to http://mcp_server:8000/mcp/
# MCP_SERVER_URL=http://127.0.0.1:8000/mcp/
